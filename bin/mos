#!/usr/bin/env python3
import sys
import os

# 1. Alineación de rutas: Localizar la raíz de MOS2
# Esto permite que el comando funcione sin importar desde dónde se llame
BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(BASE_DIR, "moslib"))

try:
    from core.shell import MOSShell
    from core.kernel import Kernel
except ImportError as e:
    print(f"Critital Error: MOS2 core not found. {e}")
    sys.exit(1)

def main():
    # Magenta Spectrum (Bright 3) - ANSI 95
    # Contraste AAA Universal
    C_MAGENTA = "\033[1;95m"
    C_RESET = "\033[0m"

    print(C_MAGENTA + "="*40)
    print(r"      __  _______  _____ ___ ")
    print(r"     /  |/  / __ \/ ___|__ \\")
    print(r"    / /|_/ / / / /\___ \__/ /")
    print(r"   / /  / / /_/ /___/ / __/ ")
    print(r"  /_/  /_/\____/|____/____/  CORE")
    print("="*40 + C_RESET)
    
    kernel = Kernel(BASE_DIR)
    kernel.boot()
    
    shell = MOSShell(kernel)
    shell.run()

if __name__ == "__main__":
    main()